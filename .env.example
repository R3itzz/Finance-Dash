# ============================================
# CONFIGURAÇÃO DO SERVIDOR
# ============================================
PORT=3001

# ============================================
# SEGURANÇA - AUTENTICAÇÃO
# ============================================
# Token API para rotas protegidas (gere um hash aleatório forte)
API_TOKEN=sua_chave_aqui

# Credenciais do Admin (use hash bcrypt para a senha)
ADMIN_EMAIL=nicolasreitz46@gmail.com
# Hash bcrypt da senha - gere com: npx bcrypt hash sua_senha
ADMIN_PASSWORD_HASH=$2a$10$exemplo_hash_aqui

# ============================================
# SEGURANÇA - CORS
# ============================================
# Origens permitidas (separadas por vírgula)
ALLOWED_ORIGIN=http://localhost:5173

# ============================================
# APIs EXTERNAS
# ============================================
# Alpha Vantage API Key (obtenha em https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_KEY=sua_api_key_aqui

# Token para o frontend (precisa do prefixo VITE_)
VITE_API_TOKEN=sua_chave_aqui
